PORT=3000

# OpenAI — used by the OrchestratorAgent for natural-language itinerary summaries.
# If absent, the orchestrator falls back to deterministic rule-based ranking (no LLM call).
OPENAI_API_KEY=

# Stripe — required for subscription tiers, checkout, and webhook handling.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ELITE=

# Used by scripts/push-github.ts
GITHUB_REPO_URL=

# Optional real data providers. Any service whose key is missing automatically
# falls back to its deterministic mock generator — the API never returns errors
# or empty results just because a provider key isn't configured.
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
SKYSCANNER_API_KEY=
BOOKING_API_KEY=
CAR_RENTAL_API_KEY=
# Private-jet charter marketplace (e.g. Avinode, Villiers, or a partner API).
# Endpoint is configurable since most charter providers issue a custom base URL per account.
JET_CHARTER_API_KEY=
JET_CHARTER_API_URL=

# Frontend (apps/web) — points the dashboard at the API above.
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
